import java.util.*;

class Product {
    private int id;
    private String name;
    private int quantity;
    private double price;

    public Product(int id, String name, int quantity, double price) {
        this.id = id;
        this.name = name;
        this.quantity = quantity;
        this.price = price;
    }

    public int getId() { return id; }
    public int getQuantity() { return quantity; }

    public void updateStock(int qty) {
        quantity += qty;
    }

    public double getValue() {
        return quantity * price;
    }

    public void display() {
        System.out.println("\nID: " + id);
        System.out.println("Name: " + name);
        System.out.println("Quantity: " + quantity);
        System.out.println("Price: " + price);
        System.out.println("Value: " + getValue());
    }
}

class Inventory {
    private ArrayList<Product> products = new ArrayList<>();
    private Scanner sc = new Scanner(System.in);

    public Product findProduct(int id) {
        for(Product p : products) {
            if(p.getId() == id)
                return p;
        }
        return null;
    }

    public void addProduct() {
        System.out.print("Enter ID: ");
        int id = sc.nextInt();
        sc.nextLine();

        if(findProduct(id) != null) {
            System.out.println("Product already exists!");
            return;
        }

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Quantity: ");
        int qty = sc.nextInt();

        System.out.print("Enter Price: ");
        double price = sc.nextDouble();

        if(qty < 0 || price < 0) {
            System.out.println("Invalid input!");
            return;
        }

        products.add(new Product(id, name, qty, price));
        System.out.println("Product added!");
    }

    public void updateProduct() {
        System.out.print("Enter Product ID: ");
        int id = sc.nextInt();

        Product p = findProduct(id);
        if(p == null) {
            System.out.println("Product not found!");
            return;
        }

        System.out.print("Enter quantity to add/remove: ");
        int qty = sc.nextInt();

        p.updateStock(qty);
        System.out.println("Stock updated!");
    }

    public void removeProduct() {
        System.out.print("Enter Product ID: ");
        int id = sc.nextInt();

        Product p = findProduct(id);
        if(p != null) {
            products.remove(p);
            System.out.println("Product removed!");
        } else {
            System.out.println("Product not found!");
        }
    }

    public void displayInventory() {
        if(products.isEmpty()) {
            System.out.println("No products available!");
            return;
        }

        for(Product p : products) {
            p.display();
            if(p.getQuantity() < 5) {
                System.out.println("Low Stock Alert!");
            }
        }

        System.out.println("\nTotal Inventory Value: " + calculateTotalValue());
    }

    public double calculateTotalValue() {
        double total = 0;
        for(Product p : products) {
            total += p.getValue();
        }
        return total;
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Inventory inv = new Inventory();

        while(true) {
            System.out.println("\n===== INVENTORY SYSTEM =====");
            System.out.println("1. Add Product");
            System.out.println("2. Update Stock");
            System.out.println("3. Remove Product");
            System.out.println("4. Display Inventory");
            System.out.println("5. Exit");

            System.out.print("Enter choice: ");

            int ch;
            try {
                ch = sc.nextInt();
            } catch(Exception e) {
                System.out.println("Invalid input!");
                sc.nextLine();
                continue;
            }

            switch(ch) {
                case 1: inv.addProduct(); break;
                case 2: inv.updateProduct(); break;
                case 3: inv.removeProduct(); break;
                case 4: inv.displayInventory(); break;
                case 5:
                    System.out.println("Exiting...");
                    return;
                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
