import java.util.*;

class Room {
    private int roomNumber;
    private String category;
    private boolean isBooked;
    private String customerName;

    public Room(int roomNumber, String category) {
        this.roomNumber = roomNumber;
        this.category = category;
        this.isBooked = false;
        this.customerName = "";
    }

    public int getRoomNumber() { return roomNumber; }
    public String getCategory() { return category; }
    public boolean isBooked() { return isBooked; }

    public void book(String name) {
        isBooked = true;
        customerName = name;
        System.out.println("Room booked successfully!");
    }

    public void cancel() {
        isBooked = false;
        customerName = "";
        System.out.println("Booking cancelled!");
    }

    public void display() {
        System.out.println("\nRoom No: " + roomNumber);
        System.out.println("Category: " + category);
        System.out.println("Status: " + (isBooked ? "Booked" : "Available"));
    }
}

class Hotel {
    private ArrayList<Room> rooms = new ArrayList<>();
    private Scanner sc = new Scanner(System.in);

    public Hotel() {
        rooms.add(new Room(101, "AC"));
        rooms.add(new Room(102, "Non-AC"));
        rooms.add(new Room(103, "AC"));
        rooms.add(new Room(104, "Non-AC"));
    }

    public Room findRoom(int roomNo) {
        for(Room r : rooms) {
            if(r.getRoomNumber() == roomNo)
                return r;
        }
        return null;
    }

    public void showAvailableRooms() {
        boolean found = false;
        for(Room r : rooms) {
            if(!r.isBooked()) {
                r.display();
                found = true;
            }
        }
        if(!found) {
            System.out.println("No available rooms!");
        }
    }

    public void bookRoom() {
        System.out.print("Enter Room No: ");
        int roomNo = sc.nextInt();
        sc.nextLine();

        Room r = findRoom(roomNo);

        if(r == null) {
            System.out.println("Room not found!");
            return;
        }

        if(r.isBooked()) {
            System.out.println("Room already booked!");
            return;
        }

        System.out.print("Enter Customer Name: ");
        String name = sc.nextLine();

        r.book(name);
    }

    public void cancelBooking() {
        System.out.print("Enter Room No: ");
        int roomNo = sc.nextInt();

        Room r = findRoom(roomNo);

        if(r == null) {
            System.out.println("Room not found!");
            return;
        }

        if(!r.isBooked()) {
            System.out.println("Room is not booked!");
            return;
        }

        r.cancel();
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Hotel hotel = new Hotel();

        while(true) {
            System.out.println("\n===== HOTEL BOOKING SYSTEM =====");
            System.out.println("1. Show Available Rooms");
            System.out.println("2. Book Room");
            System.out.println("3. Cancel Booking");
            System.out.println("4. Exit");

            System.out.print("Enter choice: ");

            int ch;
            try {
                ch = sc.nextInt();
            } catch(Exception e) {
                System.out.println("Invalid input!");
                sc.nextLine();
                continue;
            }

            switch(ch) {
                case 1: hotel.showAvailableRooms(); break;
                case 2: hotel.bookRoom(); break;
                case 3: hotel.cancelBooking(); break;
                case 4:
                    System.out.println("Exiting...");
                    return;
                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
