import java.util.*;

class PasswordResult {
    int score;
    String strength;
    ArrayList<String> suggestions;

    public PasswordResult(int score, String strength, ArrayList<String> suggestions) {
        this.score = score;
        this.strength = strength;
        this.suggestions = suggestions;
    }

    public void display() {
        System.out.println("\nScore: " + score);
        System.out.println("Strength: " + strength);
        System.out.println("Suggestions:");
        if(suggestions.isEmpty()) {
            System.out.println("None");
        } else {
            for(String s : suggestions) {
                System.out.println("- " + s);
            }
        }
    }
}

class PasswordChecker {

    private List<String> commonPasswords = Arrays.asList(
        "123456","password","12345678","qwerty","abc123","111111","123123"
    );

    public boolean hasUppercase(String p) {
        return p.matches(".*[A-Z].*");
    }

    public boolean hasLowercase(String p) {
        return p.matches(".*[a-z].*");
    }

    public boolean hasDigit(String p) {
        return p.matches(".*[0-9].*");
    }

    public boolean hasSpecial(String p) {
        return p.matches(".*[^a-zA-Z0-9].*");
    }

    public boolean hasNoSpaces(String p) {
        return !p.contains(" ");
    }

    public boolean hasRepeatedChars(String p) {
        for(int i = 1; i < p.length(); i++) {
            if(p.charAt(i) == p.charAt(i-1))
                return true;
        }
        return false;
    }

    public boolean isCommonPassword(String p) {
        return commonPasswords.contains(p.toLowerCase());
    }

    public PasswordResult evaluate(String p) {

        int score = 0;
        ArrayList<String> suggestions = new ArrayList<>();

        if(p == null || p.trim().isEmpty()) {
            suggestions.add("Password cannot be empty");
            return new PasswordResult(0, "Invalid", suggestions);
        }

        if(p.length() >= 8) score++;
        else suggestions.add("Use at least 8 characters");

        if(p.length() >= 12) score++;

        if(hasUppercase(p)) score++;
        else suggestions.add("Add uppercase letter");

        if(hasLowercase(p)) score++;
        else suggestions.add("Add lowercase letter");

        if(hasDigit(p)) score++;
        else suggestions.add("Add digit");

        if(hasSpecial(p)) score++;
        else suggestions.add("Add special character");

        if(!hasNoSpaces(p))
            suggestions.add("Remove spaces");

        if(hasRepeatedChars(p))
            suggestions.add("Avoid repeated characters");

        if(isCommonPassword(p)) {
            suggestions.add("Avoid common passwords");
            score = 0;
        }

        String strength;

        if(score <= 2) strength = "Weak";
        else if(score <= 4) strength = "Medium";
        else if(score <= 6) strength = "Strong";
        else strength = "Very Strong";

        return new PasswordResult(score, strength, suggestions);
    }
}

public class Main {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        PasswordChecker checker = new PasswordChecker();

        while(true) {
            System.out.println("\n===== PASSWORD STRENGTH CHECKER =====");
            System.out.println("1. Check Password");
            System.out.println("2. Exit");

            System.out.print("Enter choice: ");
            int ch = sc.nextInt();
            sc.nextLine();

            switch(ch) {

                case 1:
                    System.out.print("Enter Password: ");
                    String password = sc.nextLine();

                    PasswordResult result = checker.evaluate(password);
                    result.display();
                    break;

                case 2:
                    System.out.println("Exiting...");
                    return;

                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
