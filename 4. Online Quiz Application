import java.util.*;

class Question {
    private String question;
    private String[] options;
    private int correct;

    public Question(String question, String[] options, int correct) {
        this.question = question;
        this.options = options;
        this.correct = correct;
    }

    public void display() {
        System.out.println("\n" + question);
        for(int i = 0; i < options.length; i++) {
            System.out.println((i+1) + ". " + options[i]);
        }
    }

    public boolean checkAnswer(int ans) {
        return ans == correct;
    }

    public int getCorrect() {
        return correct;
    }

    public String getCorrectOption() {
        return options[correct - 1];
    }
}

class Quiz {
    private ArrayList<Question> questions = new ArrayList<>();
    private int score = 0;

    public void addQuestion(Question q) {
        questions.add(q);
    }

    public void startQuiz() {
        Scanner sc = new Scanner(System.in);

        for(int i = 0; i < questions.size(); i++) {
            Question q = questions.get(i);
            q.display();

            System.out.print("Enter answer: ");
            int ans;

            try {
                ans = sc.nextInt();
            } catch(Exception e) {
                System.out.println("Invalid input!");
                sc.nextLine();
                i--;
                continue;
            }

            if(q.checkAnswer(ans)) {
                score++;
            }
        }

        displayResult();
    }

    public void displayResult() {
        System.out.println("\n===== RESULT =====");
        System.out.println("Score: " + score + "/" + questions.size());

        System.out.println("\nCorrect Answers:");
        for(int i = 0; i < questions.size(); i++) {
            Question q = questions.get(i);
            System.out.println((i+1) + ". " + q.getCorrectOption());
        }
    }
}

public class Main {
    public static void main(String[] args) {
        Quiz quiz = new Quiz();

        quiz.addQuestion(new Question(
            "What is Java?",
            new String[]{"Programming Language", "Car", "Animal", "City"},
            1
        ));

        quiz.addQuestion(new Question(
            "Which is not OOP concept?",
            new String[]{"Encapsulation", "Polymorphism", "Compilation", "Inheritance"},
            3
        ));

        quiz.addQuestion(new Question(
            "Which keyword is used for inheritance?",
            new String[]{"this", "super", "extends", "implements"},
            3
        ));

        quiz.startQuiz();
    }
}
